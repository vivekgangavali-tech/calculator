<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:padding="12dp">

    <!-- History Panel -->
    <LinearLayout
        android:id="@+id/historyPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="#2C2C2E"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="History"
                android:textColor="#F2F2F7"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textSize="12sp"
                android:textColor="#FF453A"
                android:backgroundTint="#3A3A3C"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="#A0A0A5"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:gravity="bottom"
            android:paddingTop="8dp"/>
    </LinearLayout>

    <!-- Display Screen -->
    <!-- Display Screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="#2C2C2E"
        android:padding="20dp"
        android:layout_marginBottom="12dp">

        <!-- History toggle button top right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">
            <Button
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🕐 History"
                android:textSize="12sp"
                android:textColor="#F2F2F7"
                android:backgroundTint="#3A3A3C"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>
        </LinearLayout>

        <!-- Push expression and result to bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom|end">

            <TextView
                android:id="@+id/tvExpression"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#8E8E93"
                android:textSize="22sp"
                android:gravity="end"
                android:maxLines="1"
                android:ellipsize="start"/>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F2F2F7"
                android:textSize="52sp"
                android:gravity="end"
                android:fontFamily="sans-serif-light"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical">

        <!-- Row 1: AC, DEL, %, ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btnAC"
                style="@style/FuncBtn"
                android:text="AC"/>
            <Button android:id="@+id/btnDel"
                style="@style/FuncBtn"
                android:text="DEL"/>
            <Button android:id="@+id/btnPercent"
                style="@style/FuncBtn"
                android:text="%"/>
            <Button android:id="@+id/btnDivide"
                style="@style/OperatorBtn"
                android:text="÷"/>
        </LinearLayout>

        <!-- Row 2: 7 8 9 × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn7" style="@style/NumberBtn" android:text="7"/>
            <Button android:id="@+id/btn8" style="@style/NumberBtn" android:text="8"/>
            <Button android:id="@+id/btn9" style="@style/NumberBtn" android:text="9"/>
            <Button android:id="@+id/btnMultiply" style="@style/OperatorBtn" android:text="×"/>
        </LinearLayout>

        <!-- Row 3: 4 5 6 − -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn4" style="@style/NumberBtn" android:text="4"/>
            <Button android:id="@+id/btn5" style="@style/NumberBtn" android:text="5"/>
            <Button android:id="@+id/btn6" style="@style/NumberBtn" android:text="6"/>
            <Button android:id="@+id/btnMinus" style="@style/OperatorBtn" android:text="−"/>
        </LinearLayout>

        <!-- Row 4: 1 2 3 + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn1" style="@style/NumberBtn" android:text="1"/>
            <Button android:id="@+id/btn2" style="@style/NumberBtn" android:text="2"/>
            <Button android:id="@+id/btn3" style="@style/NumberBtn" android:text="3"/>
            <Button android:id="@+id/btnPlus" style="@style/OperatorBtn" android:text="+"/>
        </LinearLayout>

        <!-- Row 5: +/- 0 . = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button android:id="@+id/btnPlusMinus"
                style="@style/FuncBtn"
                android:text="+/−"/>
            <Button android:id="@+id/btn0" style="@style/NumberBtn" android:text="0"/>
            <Button android:id="@+id/btnDot" style="@style/NumberBtn" android:text="."/>
            <Button android:id="@+id/btnEquals"
                style="@style/OperatorBtn"
                android:backgroundTint="#FF9500"
                android:text="="/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>